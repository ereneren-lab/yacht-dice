{
  "name": "yacht-dice",
  "version": "1.207.0",
  "description": "주사위 골목 — 윷놀이·요트·너클본즈·라이어·좌중우 5게임 허브. 로컬/AI/온라인(서버 권위형) 멀티플레이 + 데스크톱 앱",
  "author": "jaesung",
  "main": "electron/main.js",
  "scripts": {
    "build": "node scripts/build-inline.js",
    "check:drift": "node scripts/check-drift.js",
    "test:fx": "node scripts/browser-test/verify-fx.js",
    "capture": "node scripts/browser-test/capture.js",
    "start": "node server.js",
    "app": "electron electron/main.js",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "test:online": "node scripts/online-test.js",
    "test:online2p": "node scripts/browser-test/verify-online.js",
    "test:seotda": "node scripts/seotda-test.js",
    "cap:sync": "node scripts/build-inline.js && npx cap sync",
    "cap:android": "npx cap open android",
    "cap:ios": "npx cap open ios"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@capacitor-community/admob": "^6.2.0",
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.jaesung.yachtdice",
    "productName": "Yacht Dice",
    "files": [
      "electron/**/*",
      "public/**/*",
      "server.js",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.games"
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Game"
    }
  }
}
